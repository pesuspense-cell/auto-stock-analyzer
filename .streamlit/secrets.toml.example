# .streamlit/secrets.toml.example
# -------------------------------------------------------
# 이 파일을 복사해서 secrets.toml 로 저장한 뒤 값을 채우세요.
# secrets.toml 은 .gitignore 에 등록되어 있어 GitHub 에 올라가지 않습니다.
#
# Streamlit Cloud 배포 시에는 대시보드 > App settings > Secrets 에
# 아래 내용을 직접 붙여넣으면 됩니다.
# -------------------------------------------------------

# Google AI Studio (https://aistudio.google.com) 에서 발급
GEMINI_API_KEY = "AIza..."

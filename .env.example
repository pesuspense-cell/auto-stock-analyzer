# ─── Redis 설정 ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── Telegram 봇 설정 ──────────────────────────────────────────────────────
# 설정 방법:
# 1. Telegram BotFather와 채팅하여 봇 생성
# 2. 봇 토큰 획득 (예: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)
# 3. 자신의 Telegram 채팅 ID 획득 (예: 1234567890)
# 4. 아래 값 설정

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── 로깅 설정 ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# 옵션: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── 데이터 수집 설정 ───────────────────────────────────────────────────────
# 폴링 간격 (초)
POLLING_INTERVAL=5

# 모니터링할 종목 코드 (쉼표 구분)
WATCH_TICKERS=005930.KS,000660.KS,005380.KS,035720.KS,AAPL,MSFT,NVDA

# ─── 분석 설정 ──────────────────────────────────────────────────────────────
# 가격 변동률 임계값 (%)
PRICE_CHANGE_THRESHOLD=2.0

# 거래량 급증 배수
VOLUME_SPIKE_THRESHOLD=1.5

# BUY/SELL 신뢰도 임계값 (0.0~1.0)
SIGNAL_CONFIDENCE_THRESHOLD=0.5

# ─── 데이터베이스 설정 (선택) ─────────────────────────────────────────────
# 분석 결과 저장 DB
DATABASE_URL=sqlite:///./data/analysis.db
# PostgreSQL 예: postgresql://user:password@localhost:5432/stock_analyzer

# ─── API 설정 (선택) ───────────────────────────────────────────────────────
# Alpha Vantage API Key (고급 기술적 지표용)
ALPHA_VANTAGE_API_KEY=

# IEX Cloud API Key (실시간 뉴스용)
IEX_CLOUD_API_KEY=

# Finnhub API Key (감정 분석용)
FINNHUB_API_KEY=

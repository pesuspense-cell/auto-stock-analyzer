# ─── Supabase ──────────────────────────────────────────────────────
# 클라이언트(브라우저)에 노출되는 공개 키 — RLS로 보호됨
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# 서버 전용(서버리스 함수에서만 사용) — 절대 클라이언트로 노출 금지.
# 캐시 테이블 쓰기/RLS 우회에 사용.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── (선택) LLM 키 — 서버 라우트에서 뉴스 요약/AI 리포트 호출 시 ─────
GEMINI_API_KEY=
GROQ_API_KEY=

# ─── (선택) 잔류 Python 워커 — 백테스트/ASA 트리거용 ───────────────
# PYTHON_WORKER_URL=https://asa-worker.up.railway.app

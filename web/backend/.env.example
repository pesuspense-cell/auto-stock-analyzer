# ─── 백엔드 환경 변수 ──────────────────────────────────────────────
# DB (기존 Streamlit 앱과 동일한 Supabase 인스턴스를 공유)
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# 앱 진입 게이트 비밀번호 (기존 _APP_PASSWORD 대체)
APP_PASSWORD=qnwkehlwk

# 외부 LLM / 데이터 API 키 (없으면 키워드 기반 폴백)
GEMINI_API_KEY=
GROQ_API_KEY=
DART_API_KEY=
KRX_ID=
KRX_PW=

# CORS 허용 오리진 (콤마 구분). 프로덕션에선 Vercel 도메인으로 교체.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
